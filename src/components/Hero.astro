---
const base = import.meta.env.BASE_URL;
---

<section class="hero" aria-label="ABCO Landscaping & Construction – Serving Eagle Lake, PA">

  <div class="hero-media" aria-hidden="true">
    <img
      src="/images/heros/ABCO-hero.webp"
      alt="Heavy excavation equipment working at sunset in Pennsylvania"
      title="Landscaping and excavation services in Eagle Lake and Covington Township, PA"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <h1 class="hero-title">
      Landscaping &amp; Excavation in Eagle Lake, PA
    </h1>
    <p class="hero-sub">
      ABCO Landscaping &amp; Construction serves Eagle Lake, Gouldsboro, and Covington Township with landscaping, excavation, tree removal, and property maintenance services.
    </p>
    <div class="hero-actions">
      <a href={`${base}contact`} class="btn btn-primary" title="Request a free landscaping or excavation estimate">
        Get a Free Estimate
      </a>
      <a href="tel:+17188771197" class="btn btn-white-outline" title="Call ABCO Landscaping and Construction at 718-877-1197">
        Call (718) 877-1197
      </a>
    </div>
    <p class="hero-trust" aria-label="Trust signals">
      Fast response <span aria-hidden="true">•</span> Licensed <span aria-hidden="true">•</span> Fully insured
    </p>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 680px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      rgba(5, 5, 5, 0.80) 0%,
      rgba(20, 10, 2, 0.55) 55%,
      rgba(13, 13, 13, 0.25) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 5rem;
    max-width: 760px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.6);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: #eae5de;
    max-width: 52ch;
    line-height: 1.65;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.55);
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    color: #d9d1c8;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-top: 1rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
  }

  .desktop-break { display: none; }

  @media (min-width: 640px) {
    .desktop-break { display: inline; }
  }

  @media (max-width: 480px) {
    .hero-actions .btn { width: 100%; justify-content: center; }
    .hero-trust { font-size: 0.9rem; }
  }
</style>
