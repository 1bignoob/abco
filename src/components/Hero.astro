---
import { Image } from 'astro:assets';
import heroImg from '../assets/ABCO-hero.webp';

const base = '/';
---

<section class="hero" aria-label="ABCO Landscaping & Construction – Serving Eagle Lake, PA">

  <div class="hero-media" aria-hidden="true">
    <Image
      src={heroImg}
      alt="Heavy excavation equipment working at sunset in Pennsylvania"
      class="hero-img"
      widths={[768, 1200, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <h1 class="hero-title">
      Abco Landscaping<br />&amp; Construction
    </h1>
    <p class="hero-sub">
      Expert landscaping, excavation, and property maintenance<br class="desktop-break" />
      serving Eagle Lake and Covington Township, PA.
    </p>
    <div class="hero-actions">
      <a href={`${base}contact`} class="btn btn-primary">Get a Free Estimate</a>
      <a href="tel:+17188771197" class="btn btn-white-outline">
        📞 (718) 877-1197
      </a>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 680px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      rgba(5, 5, 5, 0.80) 0%,
      rgba(20, 10, 2, 0.55) 55%,
      rgba(13, 13, 13, 0.25) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 5rem;
    max-width: 760px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.6);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: #eae5de;
    max-width: 52ch;
    line-height: 1.65;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.55);
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .desktop-break { display: none; }

  @media (min-width: 640px) {
    .desktop-break { display: inline; }
  }

  @media (max-width: 480px) {
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
