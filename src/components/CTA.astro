---
interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = 'Ready to Get Started?',
  subtext  = 'Call us today for a free estimate — no pressure, no obligation.',
} = Astro.props;
---

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="container cta-inner">
    <div class="cta-text">
      <h2 id="cta-heading">{heading}</h2>
      <p>{subtext}</p>
    </div>
    <div class="cta-actions">
      <a href="tel:+17188771197" class="btn btn-primary cta-phone">
        📞 (718) 877-1197
      </a>
      <a href="/contact" class="btn btn-white-outline">
        Request an Estimate
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: #d95210;
    padding-block: 3.5rem;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-text h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    color: #fff;
    margin-bottom: 0.4rem;
  }

  .cta-text p {
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.1rem;
    max-width: 46ch;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .cta-phone {
    background-color: #0d0d0d;
    color: #fff;
  }
  .cta-phone:hover,
  .cta-phone:focus {
    background-color: #1a1a1a;
    color: #fff;
  }

  .btn-white-outline {
    background-color: transparent;
    color: #fff;
    border-color: #fff;
  }
  .btn-white-outline:hover,
  .btn-white-outline:focus {
    background-color: #fff;
    color: #d95210;
  }

  @media (max-width: 720px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-actions .btn { width: 100%; text-align: center; }
  }
</style>
