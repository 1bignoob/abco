---
---

<section class="contact-section section" aria-labelledby="contact-heading" id="contact">
  <div class="container contact-grid">

    <div class="contact-text">
      <h2 id="contact-heading">Get In Touch</h2>
      <hr class="orange-line" aria-hidden="true" />
      <p>
        Have a question or need an estimate? Fill out the form and
        we'll get back to you as soon as possible. You can also call
        or email us directly.
      </p>
      <ul class="contact-details" aria-label="Contact details">
        <li>
          <span aria-hidden="true">📞</span>
          <a href="tel:+17188771197">(718) 877-1197</a>
        </li>
        <li>
          <span aria-hidden="true">✉️</span>
          <a href="mailto:sales@abcoguys.com">sales@abcoguys.com</a>
        </li>
        <li>
          <span aria-hidden="true">🌐</span>
          <a href="https://abcoguys.com">abcoguys.com</a>
        </li>
      </ul>
    </div>

    <div class="contact-form-wrap">
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="contact-form"
        aria-label="Contact form"
        novalidate
      >
        <input type="hidden" name="access_key" value="45cf7455-aaec-477c-b046-b458c3c8a9bf" />
        <input type="hidden" name="subject" id="cf-subject" value="New message from abcoguys.com" />
        <input type="hidden" name="redirect" value="false" />
        <!-- Honeypot spam protection -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

        <div class="form-row">
          <div class="form-field">
            <label for="cf-name">Your Name <span aria-hidden="true" class="required">*</span></label>
            <input
              type="text"
              id="cf-name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="Jane Smith"
            />
          </div>
          <div class="form-field">
            <label for="cf-phone">Phone Number</label>
            <input
              type="tel"
              id="cf-phone"
              name="phone"
              autocomplete="tel"
              placeholder="(555) 000-0000"
            />
          </div>
        </div>

        <div class="form-field">
          <label for="cf-email">Email Address <span aria-hidden="true" class="required">*</span></label>
          <input
            type="email"
            id="cf-email"
            name="email"
            autocomplete="email"
            required
            aria-required="true"
            placeholder="you@example.com"
          />
        </div>

        <div class="form-field">
          <label for="cf-service">Service Needed</label>
          <select id="cf-service" name="service">
            <option value="">— Select a service —</option>
            <option value="Landscaping">Landscaping</option>
            <option value="Excavation">Excavation</option>
            <option value="Property Maintenance">Property Maintenance</option>
            <option value="Other">Other / Not Sure</option>
          </select>
        </div>

        <div class="form-field">
          <label for="cf-message">Message <span aria-hidden="true" class="required">*</span></label>
          <textarea
            id="cf-message"
            name="message"
            rows="5"
            required
            aria-required="true"
            placeholder="Describe what you need..."
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary" id="cf-submit">Send Message</button>

      </form>

      <div id="cf-thankyou" class="cf-thankyou" aria-live="polite" hidden>
        <div class="ty-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52" fill="none" aria-hidden="true">
            <circle cx="26" cy="26" r="25" stroke="#d95210" stroke-width="2"/>
            <path d="M14 27l9 9 15-18" stroke="#d95210" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Message Received!</h3>
        <p>Thanks for reaching out. We'll be in touch shortly — usually within one business day.</p>
      </div>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const thankyou = document.getElementById('cf-thankyou') as HTMLElement | null;
  const nameInput = document.getElementById('cf-name') as HTMLInputElement | null;
  const subjectInput = document.getElementById('cf-subject') as HTMLInputElement | null;

  // Keep subject in sync with name field
  nameInput?.addEventListener('input', () => {
    if (subjectInput && nameInput.value.trim()) {
      subjectInput.value = `${nameInput.value.trim()} sent a message through abcoguys.com`;
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        form.reset();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Thank you';
          submitBtn.classList.add('btn-sent');
        }
        if (thankyou) thankyou.hidden = false;
      } else {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Message'; }
        alert('Something went wrong. Please try calling us at (718) 877-1197.');
      }
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Message'; }
      alert('Network error. Please try calling us at (718) 877-1197.');
    }
  });
</script>

<style>
  .contact-section { background-color: #111111; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-text p {
    color: #a09890;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .contact-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .contact-details li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.1rem;
  }

  .contact-details a {
    color: #f0ede8;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  .contact-details a:hover { color: #d95210; }

  /* Form */
  .contact-form-wrap {
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 10px;
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 1rem;
    font-weight: 600;
    color: #d0c8c0;
  }

  .required { color: #d95210; }

  input[type="text"],
  input[type="tel"],
  input[type="email"],
  select,
  textarea {
    background: #111111;
    border: 1px solid #383838;
    border-radius: 4px;
    color: #f0ede8;
    font-family: inherit;
    font-size: 1.05rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s;
    width: 100%;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #d95210;
    outline: none;
    box-shadow: 0 0 0 3px rgba(217, 82, 16, 0.25);
  }

  textarea { resize: vertical; min-height: 130px; }

  select option { background: #1a1a1a; }

  .contact-form .btn {
    align-self: flex-start;
    font-size: 1.1rem;
    padding: 0.9rem 2.25rem;
  }

  .contact-form .btn-sent {
    background: #444 !important;
    color: #888 !important;
    border-color: #444 !important;
    cursor: default;
  }

  .cf-thankyou {
    text-align: center;
    padding: 3rem 2rem;
  }

  .ty-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .ty-icon svg {
    width: 56px;
    height: 56px;
  }

  .cf-thankyou h3 {
    font-size: 1.6rem;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cf-thankyou p {
    color: #a09890;
    font-size: 1.05rem;
  }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
