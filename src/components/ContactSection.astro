---
// Web3Forms placeholder — replace ACCESS_KEY with your actual key from web3forms.com
// The user will migrate the real form here.
---

<section class="contact-section section" aria-labelledby="contact-heading" id="contact">
  <div class="container contact-grid">

    <div class="contact-text">
      <h2 id="contact-heading">Get In Touch</h2>
      <hr class="orange-line" aria-hidden="true" />
      <p>
        Have a question or need an estimate? Fill out the form and
        we'll get back to you as soon as possible. You can also call
        or email us directly.
      </p>
      <ul class="contact-details" aria-label="Contact details">
        <li>
          <span aria-hidden="true">📞</span>
          <a href="tel:+17188771197">(718) 877-1197</a>
        </li>
        <li>
          <span aria-hidden="true">✉️</span>
          <a href="mailto:sales@abcoguys.com">sales@abcoguys.com</a>
        </li>
        <li>
          <span aria-hidden="true">🌐</span>
          <a href="https://abcoguys.com">abcoguys.com</a>
        </li>
      </ul>
    </div>

    <!-- ================================================
         WEB3FORMS PLACEHOLDER
         Replace YOUR_ACCESS_KEY with the real key from
         https://web3forms.com/ before going live.
         ================================================ -->
    <div class="contact-form-wrap">
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="contact-form"
        aria-label="Contact form"
        novalidate
      >
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
        <input type="hidden" name="subject" value="New message from abcoguys.com" />
        <!-- Honeypot spam protection -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

        <div class="form-row">
          <div class="form-field">
            <label for="cf-name">Your Name <span aria-hidden="true" class="required">*</span></label>
            <input
              type="text"
              id="cf-name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="Jane Smith"
            />
          </div>
          <div class="form-field">
            <label for="cf-phone">Phone Number</label>
            <input
              type="tel"
              id="cf-phone"
              name="phone"
              autocomplete="tel"
              placeholder="(555) 000-0000"
            />
          </div>
        </div>

        <div class="form-field">
          <label for="cf-email">Email Address <span aria-hidden="true" class="required">*</span></label>
          <input
            type="email"
            id="cf-email"
            name="email"
            autocomplete="email"
            required
            aria-required="true"
            placeholder="you@example.com"
          />
        </div>

        <div class="form-field">
          <label for="cf-service">Service Needed</label>
          <select id="cf-service" name="service">
            <option value="">— Select a service —</option>
            <option value="Landscaping">Landscaping</option>
            <option value="Excavation">Excavation</option>
            <option value="Property Maintenance">Property Maintenance</option>
            <option value="Other">Other / Not Sure</option>
          </select>
        </div>

        <div class="form-field">
          <label for="cf-message">Message <span aria-hidden="true" class="required">*</span></label>
          <textarea
            id="cf-message"
            name="message"
            rows="5"
            required
            aria-required="true"
            placeholder="Describe what you need..."
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Send Message</button>

      </form>
    </div>

  </div>
</section>

<style>
  .contact-section { background-color: #111111; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-text p {
    color: #a09890;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .contact-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .contact-details li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.1rem;
  }

  .contact-details a {
    color: #f0ede8;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  .contact-details a:hover { color: #d95210; }

  /* Form */
  .contact-form-wrap {
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 10px;
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 1rem;
    font-weight: 600;
    color: #d0c8c0;
  }

  .required { color: #d95210; }

  input[type="text"],
  input[type="tel"],
  input[type="email"],
  select,
  textarea {
    background: #111111;
    border: 1px solid #383838;
    border-radius: 4px;
    color: #f0ede8;
    font-family: inherit;
    font-size: 1.05rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s;
    width: 100%;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #d95210;
    outline: none;
    box-shadow: 0 0 0 3px rgba(217, 82, 16, 0.25);
  }

  textarea { resize: vertical; min-height: 130px; }

  select option { background: #1a1a1a; }

  .contact-form .btn {
    align-self: flex-start;
    font-size: 1.1rem;
    padding: 0.9rem 2.25rem;
  }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
