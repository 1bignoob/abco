---
// Generates breadcrumb from the URL path automatically.
// Homepage: shows "Home" only (not clickable).
// All other pages: Home (link) / Current Page
// Pages with sub-paths (e.g. /services/landscaping): Home / Services / Landscaping

const { pathname } = Astro.url;

const segmentLabels: Record<string, string> = {
  services:             'Services',
  blog:                 'Blog',
  about:                'About',
  faq:                  'FAQ',
  contact:              'Contact',
  landscaping:          'Landscaping',
  excavation:           'Excavation',
  'property-maintenance': 'Property Maintenance',
  'terms-of-use':       'Terms of Use',
  'privacy-policy':     'Privacy Policy',
  disclaimer:           'Disclaimer',
};

// Build breadcrumb items from path segments
const segments = pathname.replace(/\/$/, '').split('/').filter(Boolean);

type CrumbItem = { label: string; href: string; current: boolean };

const crumbs: CrumbItem[] = [
  { label: 'Home', href: '/', current: segments.length === 0 },
];

segments.forEach((seg, i) => {
  const href = '/' + segments.slice(0, i + 1).join('/');
  const label = segmentLabels[seg] ?? seg.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  crumbs.push({ label, href, current: i === segments.length - 1 });
});

const isHome = segments.length === 0;
---

{/* Only render the bar on all pages */}
<nav class="breadcrumb-bar" aria-label="Breadcrumb">
  <div class="container">
    <ol class="crumb-list">
      {isHome ? (
        <li class="crumb-item crumb-current" aria-current="page">Home</li>
      ) : (
        crumbs.map((crumb, i) => (
          crumb.current ? (
            <li class="crumb-item crumb-current" aria-current="page">{crumb.label}</li>
          ) : (
            <li class="crumb-item">
              <a href={crumb.href}>{crumb.label}</a>
              <span class="crumb-sep" aria-hidden="true">/</span>
            </li>
          )
        ))
      )}
    </ol>
  </div>
</nav>

<style>
  .breadcrumb-bar {
    background-color: #111111;
    border-bottom: 1px solid #1e1e1e;
    padding-block: 0.55rem;
  }

  .crumb-list {
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    font-size: 0.9rem;
  }

  .crumb-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #706860;
  }

  .crumb-item a {
    color: #a09890;
    text-decoration: none;
    transition: color 0.2s;
  }
  .crumb-item a:hover { color: #d95210; }

  .crumb-current {
    color: #d95210;
    font-weight: 600;
  }

  .crumb-sep {
    color: #383838;
    font-size: 0.8rem;
  }
</style>
