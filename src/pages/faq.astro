---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const faqs = [
  {
    category: 'General',
    items: [
      {
        q: 'What areas do you serve?',
        a: 'We primarily serve Eagle Lake, Gouldsboro, and Covington Township PA (ZIP 18424) and surrounding communities in Wayne and Lackawanna County.',
      },
      {
        q: 'Do you offer free estimates?',
        a: 'Yes. All estimates are free and come with no obligation. Contact us to schedule a site visit or describe your project over the phone.',
      },
      {
        q: 'What are your business hours?',
        a: 'Monday through Friday 8:00 AM – 6:00 PM, Saturday 9:30 AM – 4:30 PM. We are closed Sundays.',
      },
      {
        q: 'How do I reach you?',
        a: 'Call (718) 877-1197, email sales@abcoguys.com, or fill out the contact form on our website. We respond as quickly as possible.',
      },
    ],
  },
  {
    category: 'Services',
    items: [
      {
        q: 'Do you work with residential and commercial customers?',
        a: 'Yes. We work with residential homeowners, commercial property managers, and RV community sites throughout the Eagle Lake area.',
      },
      {
        q: 'Can you handle both small and large jobs?',
        a: 'Absolutely. We take on everything from routine lawn maintenance to major excavation and site clearing projects.',
      },
      {
        q: 'Do you offer ongoing maintenance contracts?',
        a: 'Yes, we can set up regular maintenance schedules for residential and commercial properties. Ask about our seasonal programs.',
      },
    ],
  },
  {
    category: 'Excavation',
    items: [
      {
        q: 'Do you handle utility marking before digging?',
        a: 'Yes — we call 811 (Pennsylvania\'s Call Before You Dig service) before every excavation job. This is standard practice on every project.',
      },
      {
        q: 'How long does a typical excavation project take?',
        a: 'Most residential excavation projects take one to three days on-site. Larger projects may take longer. We give you a realistic timeline upfront.',
      },
    ],
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(cat =>
    cat.items.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a,
      },
    }))
  ),
};
---

<BaseLayout
  title="Landscaping, Excavation & Property Maintenance FAQs | Eagle Lake, PA"
  description="Read common questions about ABCO Landscaping & Construction services in Eagle Lake, Gouldsboro, and Covington Township, PA."
  canonical="/faq"
  schemaJson={faqSchema}
>

  <div class="page-header">
    <div class="container">
      <h1>Landscaping, Excavation &amp; Property Maintenance FAQs</h1>
      <p>Answers to the most common questions we hear from Eagle Lake and Gouldsboro area customers.</p>
    </div>
  </div>

  <section class="faq-page section">
    <div class="container faq-layout">

      <div class="faq-content">
        {faqs.map(cat => (
          <div class="faq-category">
            <h2>{cat.category}</h2>
            <dl class="faq-list">
              {cat.items.map(item => (
                <div class="faq-item">
                  <dt>{item.q}</dt>
                  <dd>{item.a}</dd>
                </div>
              ))}
            </dl>
          </div>
        ))}
      </div>

      <aside class="faq-sidebar">
        <div class="sidebar-box">
          <h3>Still Have a Landscaping or Excavation Question?</h3>
          <p>Give us a call or send a message — we're happy to help.</p>
          <a href="tel:+17188771197" class="btn btn-primary" style="width:100%;text-align:center;margin-bottom:0.75rem;" title="Call ABCO Landscaping and Construction">
            📞 (718) 877-1197
          </a>
          <a href={`${base}contact`} class="btn btn-outline" style="width:100%;text-align:center;" title="Open the ABCO contact form">
            Contact Form
          </a>
        </div>
        <div class="sidebar-box">
          <h3>Explore Our Services</h3>
          <ul>
            <li><a href={`${base}services/landscaping`} title="View landscaping services in Eagle Lake, PA">Landscaping</a></li>
            <li><a href={`${base}services/excavation`} title="View excavation services in Eagle Lake, PA">Excavation</a></li>
            <li><a href={`${base}services/property-maintenance`} title="View property maintenance services in Eagle Lake, PA">Property Maintenance</a></li>
          </ul>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 3rem 2.5rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .page-header p { color: #a09890; font-size: 1.1rem; max-width: 65ch; }

  .faq-page { background: #0d0d0d; }

  .faq-layout { display: grid; grid-template-columns: 1fr 280px; gap: 3rem; align-items: start; }

  .faq-category { margin-bottom: 3rem; }
  .faq-category h2 { font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.08em; color: #d95210; margin-bottom: 1.25rem; }

  .faq-list { display: flex; flex-direction: column; gap: 0; border: 1px solid #2e2e2e; border-radius: 8px; overflow: hidden; }

  .faq-item { padding: 1.5rem 1.75rem; border-bottom: 1px solid #2e2e2e; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item dt { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
  .faq-item dd { margin-left: 0; color: #a09890; font-size: 1.05rem; line-height: 1.75; max-width: 70ch; }

  .faq-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
  .sidebar-box { background: #1a1a1a; border: 1px solid #2e2e2e; border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .sidebar-box h3 { font-size: 1rem; color: #d95210; text-transform: uppercase; letter-spacing: 0.07em; }
  .sidebar-box p { color: #a09890; font-size: 0.95rem; max-width: none; }
  .sidebar-box ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-box ul a { color: #c0b8b0; text-decoration: none; font-size: 1rem; transition: color 0.2s; }
  .sidebar-box ul a:hover { color: #d95210; }

  @media (max-width: 800px) { .faq-layout { grid-template-columns: 1fr; } }
</style>
