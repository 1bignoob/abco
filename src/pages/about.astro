---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About ABCO Landscaping & Construction in Eagle Lake, PA"
  description="Learn about ABCO Landscaping & Construction, a local company serving Eagle Lake, Gouldsboro, and Covington Township, PA with landscaping, excavation, and property maintenance."
  canonical="/about"
>

  <div class="page-header">
    <div class="container">
      <h1>About ABCO Landscaping &amp; Construction in Eagle Lake, PA</h1>
      <p>Serving Eagle Lake, Gouldsboro &amp; Covington Township, PA</p>
    </div>
  </div>

  <section class="about-section section">
    <div class="container about-grid">

      <div class="about-content">
        <h2>Who We Are as a Local Landscaping and Excavation Company</h2>
        <hr class="orange-line" aria-hidden="true" />
        <p>
          ABCO Landscaping &amp; Construction — known locally as ABCO Guys — has been doing outdoor
          work the right way in the Eagle Lake and Gouldsboro, PA area. We're a hands-on crew that
          takes pride in showing up, doing quality work, and leaving your property better than we found it.
        </p>
        <p>
          Our work spans residential homes, commercial properties, and RV community sites throughout
          Covington Township and the surrounding northeastern Pennsylvania region.
        </p>

        <h2>What We Value on Every Outdoor Service Project</h2>
        <ul class="about-list">
          <li><strong>Reliability</strong> — We show up when we say we will.</li>
          <li><strong>Honest pricing</strong> — Free estimates, no pressure, no hidden costs.</li>
          <li><strong>Quality work</strong> — We don't cut corners. If something isn't right, we fix it.</li>
          <li><strong>Local knowledge</strong> — We know this area, the soil, the seasons, and what works here.</li>
        </ul>

        <h2>Our Landscaping and Excavation Service Area</h2>
        <p>
          We primarily serve Eagle Lake, Gouldsboro, and Covington Township PA (ZIP 18424) and
          surrounding communities. Not sure if we cover your area?
          <a href={`${base}contact`} title="Contact ABCO to confirm your service area">Just ask</a> — we're happy to let you know.
        </p>

        <div class="about-cta">
          <a href={`${base}contact`} class="btn btn-primary" title="Request a free estimate from ABCO Landscaping and Construction">Get a Free Estimate</a>
          <a href={`${base}services`} class="btn btn-outline" title="View landscaping, excavation, and property maintenance services">Our Services</a>
        </div>
      </div>

      <aside class="about-sidebar">
        <div class="sidebar-box">
          <h3>Contact ABCO Landscaping</h3>
          <ul>
            <li><a href="tel:+17188771197" title="Call ABCO Landscaping and Construction">(718) 877-1197</a></li>
            <li><a href="mailto:sales@abcoguys.com" title="Email ABCO Landscaping and Construction">sales@abcoguys.com</a></li>
            <li><a href="https://abcoguys.com" title="Visit abcoguys.com">abcoguys.com</a></li>
          </ul>
        </div>
        <div class="sidebar-box">
          <h3>Business Hours in Eagle Lake, PA</h3>
          <ul class="hours-list">
            <li><span>Mon – Fri</span><span>8 AM – 6 PM</span></li>
            <li><span>Saturday</span><span>9:30 AM – 4:30 PM</span></li>
            <li><span>Sunday</span><span>Closed</span></li>
          </ul>
        </div>
        <div class="sidebar-box">
          <h3>Follow ABCO on Facebook</h3>
          <a
            href="https://www.facebook.com/share/1b15VtsNao/?mibextid=wwXIfr"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            title="Visit ABCO Landscaping and Construction on Facebook"
          >
            Facebook →
          </a>
        </div>
      </aside>

    </div>
  </section>

  <CTA />

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 3rem 2.5rem;
  }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: #d95210; font-size: 1.1rem; font-weight: 600; max-width: none; }

  .about-section { background: #0d0d0d; }

  .about-grid { display: grid; grid-template-columns: 1fr 280px; gap: 3rem; align-items: start; }

  .about-content h2 { font-size: 1.5rem; margin-bottom: 0.25rem; margin-top: 2rem; }
  .about-content h2:first-child { margin-top: 0; }
  .about-content p { color: #a09890; font-size: 1.1rem; line-height: 1.75; margin-bottom: 1.25rem; }
  .about-content a:not(.btn) { color: #d95210; }

  .about-list { list-style: none; padding: 0; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .about-list li { color: #c0b8b0; font-size: 1.1rem; padding-left: 1.5rem; position: relative; line-height: 1.6; }
  .about-list li::before { content: '→'; color: #d95210; position: absolute; left: 0; font-weight: 700; }
  .about-list strong { color: #fff; }

  .about-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }

  .about-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
  .sidebar-box { background: #1a1a1a; border: 1px solid #2e2e2e; border-radius: 8px; padding: 1.5rem; }
  .sidebar-box h3 { font-size: 1rem; color: #d95210; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 1rem; }
  .sidebar-box ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-box li { font-size: 1rem; }
  .sidebar-box a { color: #c0b8b0; text-decoration: none; transition: color 0.2s; }
  .sidebar-box a:hover { color: #d95210; }

  .hours-list li { display: flex; justify-content: space-between; gap: 0.5rem; font-size: 1rem; color: #908880; }
  .hours-list li span:first-child { color: #c0b8b0; }

  .social-link { display: inline-block; color: #d95210 !important; font-weight: 700; font-size: 1.05rem; }

  @media (max-width: 800px) { .about-grid { grid-template-columns: 1fr; } }
</style>
