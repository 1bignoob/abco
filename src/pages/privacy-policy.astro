---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Privacy Policy | ABCO Landscaping & Construction"
  description="Privacy policy for abcoguys.com and ABCO Landscaping & Construction."
  canonical="/privacy-policy"
  noindex={true}
>

  <div class="page-header">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p>Last updated: April 2026</p>
    </div>
  </div>

  <section class="legal-section section">
    <div class="container legal-content">

      <p>ABCO Landscaping &amp; Construction ("we", "us") operates abcoguys.com. This policy explains how we collect, use, and protect your information.</p>

      <h2>Information We Collect</h2>
      <p>We collect information you voluntarily provide through our contact form, including your name, email address, phone number, and message content. We do not collect information automatically beyond what is standard in web server logs.</p>

      <h2>How We Use Your Information</h2>
      <p>Information you submit is used solely to respond to your inquiry and provide you with service estimates. We do not sell, rent, or share your personal information with third parties for marketing purposes.</p>

      <h2>Contact Form</h2>
      <p>Our contact form is processed through Web3Forms. Please review <a href="https://web3forms.com/privacy" target="_blank" rel="noopener noreferrer" title="Read the Web3Forms privacy policy">Web3Forms' privacy policy</a> for information on how form submissions are handled.</p>

      <h2>Cookies</h2>
      <p>This website does not use tracking cookies or analytics scripts. Standard server logs may record your IP address and browser information as part of normal web server operation.</p>

      <h2>Data Security</h2>
      <p>We take reasonable precautions to protect your information, but no method of transmission over the internet is 100% secure.</p>

      <h2>Children's Privacy</h2>
      <p>This site is not directed at children under 13. We do not knowingly collect information from children.</p>

      <h2>Changes to This Policy</h2>
      <p>We may update this policy from time to time. Changes will be posted on this page with an updated date.</p>

      <h2>Contact ABCO Landscaping &amp; Construction</h2>
      <p>Questions about this policy? <a href={`${base}contact`} title="Contact ABCO about this privacy policy">Contact us</a> or call <a href="tel:+17188771197" title="Call ABCO Landscaping and Construction">(718) 877-1197</a>.</p>

    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 2.5rem 2rem;
  }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: #706860; font-size: 1rem; max-width: none; }

  .legal-section { background: #0d0d0d; }

  .legal-content { max-width: 760px; }

  .legal-content h2 { font-size: 1.3rem; margin-top: 2.5rem; margin-bottom: 0.5rem; color: #fff; }

  .legal-content p { color: #a09890; font-size: 1.05rem; line-height: 1.75; margin-bottom: 1rem; }

  .legal-content a { color: #d95210; }
</style>
