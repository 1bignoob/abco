---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createLegalPageSchema } from '../lib/schema';
const base = import.meta.env.BASE_URL;
const termsSchema = createLegalPageSchema({
  path: '/terms-of-use/',
  name: 'Terms of Use | ABCO Landscaping & Construction',
  description: 'Terms of use for abcoguys.com and ABCO Landscaping & Construction.',
});
---

<BaseLayout
  title="Terms of Use | ABCO Landscaping & Construction"
  description="Terms of use for abcoguys.com and ABCO Landscaping & Construction."
  canonical="/terms-of-use/"
  noindex={true}
  schemaJson={termsSchema}
>

  <div class="page-header">
    <div class="container">
      <h1>Terms of Use</h1>
      <p>Last updated: April 2026</p>
    </div>
  </div>

  <section class="legal-section section">
    <div class="container legal-content">

      <p>By accessing and using abcoguys.com, you agree to be bound by these Terms of Use. If you do not agree with any part of these terms, please do not use this website.</p>

      <h2>Use of This Website</h2>
      <p>This website is provided for informational purposes related to ABCO Landscaping &amp; Construction's services. You agree not to use this site for any unlawful purpose or in a manner that could damage, disable, or impair the site.</p>

      <h2>Intellectual Property</h2>
      <p>All content on this website — including text, images, and design — is the property of ABCO Landscaping &amp; Construction or its content providers. Unauthorized reproduction is prohibited.</p>

      <h2>Disclaimer of Warranties</h2>
      <p>This site is provided "as is" without warranties of any kind. ABCO Landscaping &amp; Construction makes no guarantees about the accuracy, completeness, or usefulness of any information on this site.</p>

      <h2>Limitation of Liability</h2>
      <p>ABCO Landscaping &amp; Construction shall not be liable for any direct, indirect, incidental, or consequential damages arising from your use of this website.</p>

      <h2>Links to Other Sites</h2>
      <p>This site may contain links to third-party websites. We are not responsible for the content or practices of those sites.</p>

      <h2>Changes to These Terms</h2>
      <p>We reserve the right to update these terms at any time. Continued use of the site following changes constitutes acceptance of the updated terms.</p>

      <h2>Contact ABCO Landscaping &amp; Construction</h2>
      <p>Questions about these terms? <a href={`${base}contact`} title="Contact ABCO about these terms">Contact us</a> or call <a href="tel:+17188771197" title="Call ABCO Landscaping and Construction">(718) 877-1197</a>.</p>

    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 2.5rem 2rem;
  }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: #706860; font-size: 1rem; max-width: none; }

  .legal-section { background: #0d0d0d; }

  .legal-content {
    max-width: 760px;
  }

  .legal-content h2 {
    font-size: 1.3rem;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .legal-content p {
    color: #a09890;
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .legal-content a { color: #d95210; }
</style>
