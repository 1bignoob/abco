---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
---

<BaseLayout
  title="Contact ABCO Landscaping & Construction | Free Estimates in Eagle Lake, PA"
  description="Contact ABCO Landscaping & Construction for landscaping, excavation, and property maintenance estimates in Eagle Lake, Gouldsboro, and Covington Township, PA."
  canonical="/contact"
>

  <div class="page-header">
    <div class="container">
      <h1>Contact ABCO Landscaping &amp; Construction for a Free Estimate</h1>
      <p>We'd love to hear from you. Fill out the form below or call us directly.</p>
    </div>
  </div>

  <ContactSection />

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #111111 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 3rem 2.5rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .page-header p { color: #a09890; font-size: 1.1rem; }
</style>
