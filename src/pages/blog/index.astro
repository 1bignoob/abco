---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Landscaping & Excavation Blog | Eagle Lake, PA Homeowner Guides"
  description="Read practical landscaping, excavation, and property care guides for homeowners in Eagle Lake, Gouldsboro, and Covington Township, PA."
  canonical="/blog"
>

  <div class="page-header">
    <div class="container">
      <h1>Landscaping, Excavation &amp; Property Care Blog</h1>
      <p>Practical guides, seasonal tips, and local know-how for Eagle Lake &amp; Gouldsboro area homeowners.</p>
    </div>
  </div>

  <section class="blog-listing section" aria-label="Blog posts">
    <div class="container">

      {posts.length === 0 && (
        <p class="no-posts">No posts yet — check back soon!</p>
      )}

      <div class="post-list">
        {posts.map(post => (
          <article class="post-row">
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()} class="post-date">
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2 class="post-title">
              <a href={`${base}blog/${post.id}`} title={`Read blog article: ${post.data.title}`}>{post.data.title}</a>
            </h2>
            <p class="post-desc">{post.data.description}</p>
            <a href={`${base}blog/${post.id}`} class="post-link" aria-label={`Read: ${post.data.title}`} title={`Read full article: ${post.data.title}`}>
              Read Full Article →
            </a>
          </article>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border-bottom: 1px solid #2e2e2e;
    padding-block: 3.5rem 2.5rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: #a09890;
    font-size: 1.15rem;
    max-width: 60ch;
  }

  .blog-listing { background: #0d0d0d; }

  .no-posts { color: #a09890; font-size: 1.1rem; }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-row {
    padding-block: 2.5rem;
    border-bottom: 1px solid #1e1e1e;
  }

  .post-row:last-child { border-bottom: none; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .post-date {
    color: #706860;
    font-size: 0.95rem;
  }

  .tag {
    background: rgba(217, 82, 16, 0.12);
    color: #d95210;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
  }

  .post-title {
    font-size: clamp(1.3rem, 3vw, 1.65rem);
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .post-title a {
    color: #fff;
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-title a:hover { color: #d95210; }

  .post-desc {
    color: #a09890;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 72ch;
  }

  .post-link {
    color: #d95210;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-link:hover { color: #f06520; }
</style>
